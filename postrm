#!/bin/sh
# postrm script for lubuntu-lark-neuroshell

set -e

uninstall_ollama() {
    echo "Purging: Attempting to remove Ollama system components..."
    # Stop and disable the systemd service
    if command -v systemctl >/dev/null 2>&1; then
        systemctl stop ollama || true
        systemctl disable ollama || true
        rm -f /etc/systemd/system/ollama.service || true
        systemctl daemon-reload || true
        systemctl reset-failed || true
    fi

    # Remove the binary
    if [ -f "/usr/local/bin/ollama" ]; then
        rm -f /usr/local/bin/ollama
        echo "Removed /usr/local/bin/ollama."
    fi

    # Remove the user and group
    if id "ollama" &>/dev/null; then
        userdel ollama || true
        echo "Removed user 'ollama'."
    fi
    if getent group "ollama" &>/dev/null; then
        groupdel ollama || true
        echo "Removed group 'ollama'."
    fi
    
    # Remove the shared data and models directory
    if [ -d "/usr/share/ollama" ]; then
        rm -rf /usr/share/ollama
        echo "Removed /usr/share/ollama directory."
    fi

    echo "Ollama purge complete. User-specific files may remain in ~/.ollama"
}

case "$1" in
    purge)
        echo "Purging all components for lubuntu-lark-neuroshell."
        # WARNING: This is destructive and will remove Ollama even if other applications are using it.
        # This is done because the user explicitly requested a 'purge'.
        uninstall_ollama
    ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade)
        # On 'remove', we do NOT uninstall ollama, as the user might want to keep it.
    ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0